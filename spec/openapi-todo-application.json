  "info": {
    "title": "Todo application",
    "description": "Application for planning your days",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ExceptionBadRequest": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "description": "Error status code",
            "default": 400,
            "example": 400
          },
          "message": {
            "type": "string",
            "description": "Error message",
            "default": "Bad Request",
            "example": "Bad Request"
          }
        },
        "required": [
          "statusCode",
          "message"
        ]
      },
      "ExceptionUnauthorized": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "description": "Error status code",
            "default": 401,
            "example": 401
          },
          "message": {
            "type": "string",
            "description": "Error message",
            "default": "Unauthorized",
            "example": "Unauthorized"
          }
        },
        "required": [
          "statusCode",
          "message"
        ]
      },
      "ExceptionServerInternal": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "description": "Error status code",
            "default": 500,
            "example": 500
          },
          "message": {
            "type": "string",
            "description": "Error message",
            "default": "Internal server",
            "example": "Internal server"
          }
        },
        "required": [
          "statusCode",
          "message"
        ]
      },
      "SignInDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email",
            "default": "",
            "example": "loowodi@gmail.com",
            "minLength": 6,
            "maxLength": 50,
            "pattern": "^(([^<>()[]\\.,;:s@\"]+(.[^<>()[]\\.,;:s@\"]+)*)|.(\".+\"))@(([[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}])|(([a-zA-Z-0-9]+.)+[a-zA-Z]{2,}))$"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "default": "123123",
            "example": "M12asdf134@@",
